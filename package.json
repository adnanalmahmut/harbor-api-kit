{
  "name": "saas-core-platform-api",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "nest build",
    "format": "prettier --write \"src/**/*.ts\" \"test/**/*.ts\"",
    "start": "nest start",
    "start:dev": "nest start --watch",
    "start:debug": "nest start --debug --watch",
    "start:prod": "node dist/src/main.js",
    "lint": "eslint \"{src,apps,libs,test}/**/*.ts\" --fix",
    "test": "node --experimental-vm-modules ./node_modules/jest/bin/jest.js --config ./test/jest-unit.json",
    "test:watch": "node --experimental-vm-modules ./node_modules/jest/bin/jest.js --config ./test/jest-unit.json --watch",
    "test:cov": "node --experimental-vm-modules ./node_modules/jest/bin/jest.js --config ./test/jest-unit.json --coverage",
    "test:e2e:prepare": "set -a && . ./.env.test && set +a && docker-compose -f docker-compose.test.yml up -d && prisma migrate deploy",
    "test:e2e": "npm run test:e2e:prepare && node --experimental-vm-modules ./node_modules/jest/bin/jest.js --config ./test/jest-e2e.json --runInBand",
    "test:debug": "node --inspect-brk -r tsconfig-paths/register -r ts-node/register node_modules/.bin/jest --runInBand",
    "docker:up": "docker-compose up -d",
    "docker:down": "docker-compose down",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:seed": "prisma db seed",
    "prisma:studio": "prisma studio"
  },
  "prisma": {
    "seed": "tsx ./prisma/seed.production.ts"
  },
  "imports": {
    "#src/*": "./dist/src/*"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "3.980.0",
    "@aws-sdk/lib-storage": "3.980.0",
    "@aws-sdk/s3-request-presigner": "3.980.0",
    "@fastify/cookie": "11.0.2",
    "@fastify/multipart": "9.4.0",
    "@google-cloud/storage": "7.18.0",
    "@nestjs/bullmq": "11.0.4",
    "@nestjs/common": "11.1.9",
    "@nestjs/config": "4.0.2",
    "@nestjs/core": "11.1.9",
    "@nestjs/platform-fastify": "11.1.9",
    "@nestjs/swagger": "11.2.3",
    "@prisma/adapter-pg": "7.2.0",
    "@prisma/client": "7.2.0",
    "@scalar/nestjs-api-reference": "1.0.24",
    "@thallesp/nestjs-better-auth": "2.2.2",
    "better-auth": "1.4.17",
    "bullmq": "5.67.1",
    "fastify": "5.6.2",
    "geoip-lite": "1.4.10",
    "ioredis": "5.9.2",
    "nestjs-i18n": "10.6.0",
    "nestjs-pino": "4.5.0",
    "nestjs-zod": "5.0.1",
    "pg": "8.16.3",
    "pino-http": "11.0.0",
    "pino-pretty": "13.1.3",
    "reflect-metadata": "0.2.2",
    "resend": "6.8.0",
    "prisma": "7.2.0",
    "rxjs": "7.8.1",
    "zod": "4.2.1"
  },
  "devDependencies": {
    "@eslint/eslintrc": "3.2.0",
    "@eslint/js": "9.18.0",
    "@nestjs/cli": "11.0.0",
    "@nestjs/schematics": "11.0.0",
    "@nestjs/testing": "11.1.9",
    "@types/geoip-lite": "1.4.4",
    "@types/jest": "29.5.14",
    "@types/node": "22.10.7",
    "@types/supertest": "6.0.2",
    "@typescript-eslint/eslint-plugin": "8.54.0",
    "@typescript-eslint/parser": "8.54.0",
    "eslint": "9.18.0",
    "eslint-config-prettier": "10.0.1",
    "eslint-plugin-prettier": "5.2.2",
    "globals": "16.0.0",
    "jest": "29.7.0",
    "prettier": "3.4.2",
    "source-map-support": "0.5.21",
    "supertest": "7.0.0",
    "ts-jest": "29.2.5",
    "ts-node": "10.9.2",
    "tsconfig-paths": "4.2.0",
    "tsx": "4.21.0",
    "typescript": "5.9.2",
    "typescript-eslint": "8.54.0"
  },
  "jest": {
    "moduleFileExtensions": [
      "js",
      "json",
      "ts"
    ],
    "rootDir": "src",
    "testRegex": ".*\\.spec\\.ts$",
    "transform": {
      "^.+\\.(t|j)s$": "ts-jest"
    },
    "collectCoverageFrom": [
      "**/*.(t|j)s"
    ],
    "coverageDirectory": "../coverage",
    "testEnvironment": "node"
  }
}
