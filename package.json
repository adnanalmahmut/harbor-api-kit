{
  "name": "harbor-api-kit",
  "version": "0.1.0",
  "private": false,
  "description": "Production-oriented NestJS API starter with Clean Architecture, session auth, RBAC, i18n, files, Redis, Prisma, Docker, and contract tests.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/adnanalmahmut/harbor-api-kit.git"
  },
  "bugs": {
    "url": "https://github.com/adnanalmahmut/harbor-api-kit/issues"
  },
  "homepage": "https://github.com/adnanalmahmut/harbor-api-kit#readme",
  "keywords": [
    "nestjs",
    "typescript",
    "clean-architecture",
    "backend-starter",
    "rbac",
    "prisma",
    "redis",
    "fastify",
    "zod",
    "openapi"
  ],
  "type": "module",
  "scripts": {
    "build": "nest build",
    "format": "prettier --write \"src/**/*.ts\" \"test/**/*.ts\"",
    "start": "nest start",
    "start:dev": "nest start --watch",
    "start:debug": "nest start --debug --watch",
    "start:prod": "node dist/src/main.js",
    "lint": "eslint \"{src,apps,libs,test}/**/*.ts\" --fix",
    "lint:check": "eslint \"{src,apps,libs,test}/**/*.ts\"",
    "test": "node --experimental-vm-modules ./node_modules/jest/bin/jest.js --config ./test/jest-unit.json",
    "test:watch": "node --experimental-vm-modules ./node_modules/jest/bin/jest.js --config ./test/jest-unit.json --watch",
    "test:cov": "node --experimental-vm-modules ./node_modules/jest/bin/jest.js --config ./test/jest-unit.json --coverage",
    "test:e2e:prepare": "set -a && . ./.env.test && set +a && docker compose -f docker-compose.test.yml up -d && prisma migrate deploy",
    "test:e2e": "npm run test:e2e:prepare && node --experimental-vm-modules ./node_modules/jest/bin/jest.js --config ./test/jest-e2e.json --runInBand",
    "test:e2e:ci": "prisma migrate deploy && node --experimental-vm-modules ./node_modules/jest/bin/jest.js --config ./test/jest-e2e.json --runInBand",
    "test:debug": "node --inspect-brk -r tsconfig-paths/register -r ts-node/register node_modules/.bin/jest --runInBand",
    "docker:up": "docker compose -f docker-compose.dev.yml up -d",
    "docker:down": "docker compose -f docker-compose.dev.yml down",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "bootstrap:rbac": "tsx ./prisma/bootstrap-rbac.ts",
    "admin:create": "tsx ./prisma/create-admin.ts",
    "prisma:seed": "prisma db seed",
    "prisma:studio": "prisma studio"
  },
  "prisma": {
    "seed": "tsx ./prisma/bootstrap-rbac.ts"
  },
  "imports": {
    "#src/*": "./dist/src/*"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "3.1029.0",
    "@aws-sdk/lib-storage": "3.1029.0",
    "@aws-sdk/s3-request-presigner": "3.1029.0",
    "@fastify/cookie": "11.0.2",
    "@fastify/multipart": "9.4.0",
    "@fastify/static": "^9.1.0",
    "@google-cloud/storage": "7.19.0",
    "@nestjs/bullmq": "11.0.4",
    "@nestjs/common": "11.1.18",
    "@nestjs/config": "4.0.4",
    "@nestjs/core": "11.1.18",
    "@nestjs/platform-fastify": "11.1.18",
    "@nestjs/swagger": "11.2.7",
    "@prisma/adapter-pg": "7.7.0",
    "@prisma/client": "7.7.0",
    "@scalar/nestjs-api-reference": "1.0.24",
    "@thallesp/nestjs-better-auth": "2.6.0",
    "better-auth": "1.6.2",
    "bullmq": "5.73.4",
    "fastify": "5.8.4",
    "geoip-lite": "1.4.10",
    "ioredis": "5.10.1",
    "nestjs-i18n": "10.6.0",
    "nestjs-pino": "4.6.1",
    "nestjs-zod": "5.3.0",
    "pg": "8.20.0",
    "pino-http": "11.0.0",
    "pino-pretty": "13.1.3",
    "prisma": "7.7.0",
    "reflect-metadata": "0.2.2",
    "resend": "6.8.0",
    "rxjs": "7.8.1",
    "zod": "4.2.1"
  },
  "devDependencies": {
    "@eslint/eslintrc": "3.2.0",
    "@eslint/js": "9.18.0",
    "@nestjs/cli": "11.0.19",
    "@nestjs/schematics": "11.0.10",
    "@nestjs/testing": "11.1.18",
    "@types/geoip-lite": "1.4.4",
    "@types/jest": "29.5.14",
    "@types/node": "22.15.29",
    "@types/supertest": "7.2.0",
    "@typescript-eslint/eslint-plugin": "8.54.0",
    "@typescript-eslint/parser": "8.54.0",
    "dotenv": "17.4.1",
    "eslint": "9.18.0",
    "eslint-config-prettier": "10.1.8",
    "eslint-plugin-prettier": "5.5.5",
    "globals": "16.0.0",
    "jest": "29.7.0",
    "prettier": "3.8.2",
    "source-map-support": "0.5.21",
    "supertest": "7.2.2",
    "ts-jest": "29.4.0",
    "ts-node": "10.9.2",
    "tsconfig-paths": "4.2.0",
    "tsx": "4.21.0",
    "typescript": "5.9.2",
    "typescript-eslint": "8.54.0"
  }
}
