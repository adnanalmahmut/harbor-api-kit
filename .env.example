# -----------------------------------------------------------------------
# Application Core Settings
# -----------------------------------------------------------------------
APP_NAME="SaaS Core Platform API"
APP_ENV=development

APP_PORT=5000
FRONTEND_URL=http://localhost:3000

# -----------------------------------------------------------------------
# Seed
# -----------------------------------------------------------------------
SEED_ADMIN_EMAIL=admin@coreapi.com
SEED_ADMIN_PASSWORD=changeme
SEED_ADMIN_FIRST_NAME=Super
SEED_ADMIN_LAST_NAME=Admin
SEED_ADMIN_LOCALE=ar-SY

# -----------------------------------------------------------------------
# API Documentation
# -----------------------------------------------------------------------
ENABLE_DOCS=true

# -----------------------------------------------------------------------
# Logging & Request Tracing
# -----------------------------------------------------------------------
LOG_LEVEL=info
LOG_PRETTY=true
REQUEST_ID_HEADER_NAME=x-request-id

# -----------------------------------------------------------------------
# Internationalization (i18n)
# -----------------------------------------------------------------------
I18N_HEADER_NAME=Accept-Language
I18N_QUERY_NAME=lang
I18N_DEFAULT_LOCALE=ar-SY

# -----------------------------------------------------------------------
# Core URLs
# -----------------------------------------------------------------------
APP_PUBLIC_URL=https://api.example.com

# -----------------------------------------------------------------------
# CORS (Origins - full scheme+host(+port))
# Example: https://app.example.com,https://app.example.org,http://localhost:3000
# -----------------------------------------------------------------------
WEB_ALLOWED_ORIGINS=http://localhost:5000,http://localhost:3000,https://app.example.com

# -----------------------------------------------------------------------
# Cookies (Domains only - no scheme, no port, no paths)
# Use only if you intentionally set cookie Domain=.example.com for subdomains.
# Note: cookies cannot be shared across different root domains anyway.
# -----------------------------------------------------------------------
COOKIE_ALLOWED_DOMAINS=example.com,localhost

# -----------------------------------------------------------------------
# Redirect / Callback allowlist (Origins only)
# Used to validate returnTo/callbackURL (prevent open redirect).
# Keep it strict and small.
# -----------------------------------------------------------------------
REDIRECT_ALLOWED_ORIGINS=http://localhost:3000,https://app.example.com

# -----------------------------------------------------------------------
# HTTP Server / Proxy
# -----------------------------------------------------------------------
FASTIFY_TRUST_PROXY=1

# -----------------------------------------------------------------------
# Database Configuration (PostgreSQL)
# -----------------------------------------------------------------------
POSTGRES_DB=core_platform
POSTGRES_USER=core_platform
POSTGRES_PASSWORD=changeme
POSTGRES_PORT=5432

# Use the correct host/port per environment (local, docker, etc.)
DATABASE_URL=postgresql://core_platform:changeme@localhost:5434/core_platform?schema=public

# -----------------------------------------------------------------------
# CSRF Protection
# -----------------------------------------------------------------------
CSRF_ENABLED=true
CSRF_HEADER_NAME=X-CSRF-Token
COOKIE_CSRF_NAME=__Host-csrf
CSRF_SAMESITE=lax
CSRF_COOKIE_SECURE=true

# -----------------------------------------------------------------------
# Cache / Queue (Redis)
# -----------------------------------------------------------------------
REDIS_URL=redis://127.0.0.1:6379
REDIS_PREFIX=scp
REDIS_DEFAULT_TTL_SEC=900

# -----------------------------------------------------------------------
# Rate Limiting
# -----------------------------------------------------------------------
RATE_LIMIT_ENABLED=true
RATE_LIMIT_POINTS=60
RATE_LIMIT_DURATION_SEC=60
RATE_LIMIT_KEY_STRATEGY=ip
RATE_LIMIT_HEADER_PREFIX=RateLimit

# -----------------------------------------------------------------------
# Authentication
# -----------------------------------------------------------------------
SESSION_TOKEN_COOKIE=__Host-session
SESSION_DATA_COOKIE=__Host-session-data
 
# Secrets - generate for each environment
BETTER_AUTH_SECRET=changeme
BETTER_AUTH_URL=http://localhost:5000/api/v1/auth

# OAuth
GOOGLE_CLIENT_ID=changeme
GOOGLE_CLIENT_SECRET=changeme

GITHUB_CLIENT_ID=changeme
GITHUB_CLIENT_SECRET=changeme

# -----------------------------------------------------------------------
# Email Service (Resend)
# -----------------------------------------------------------------------
RESEND_API_KEY=changeme
RESEND_FROM_EMAIL=notify@feedogo.com
RESEND_FROM_NAME=FeedoGo

# -----------------------------------------------------------------------
# Tenant
# -----------------------------------------------------------------------
TENANT_STRATEGY=subdomain
TENANT_REQUIRED=true
TENANT_HEADER_NAME=X-Tenant

# -----------------------------------------------------------------------
# Storage
# -----------------------------------------------------------------------
STORAGE_DRIVER=r2
S3_ENDPOINT=changeme
S3_REGION=auto
S3_ACCESS_KEY_ID=changeme
S3_SECRET_ACCESS_KEY=changeme
S3_BUCKET=core-api

# LOCAL_STORAGE_PATH=./uploads
