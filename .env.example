# -----------------------------------------------------------------------
# App Core
# -----------------------------------------------------------------------
APP_NAME=harbor-api-kit
APP_ENV=development
APP_PORT=5000 

# -----------------------------------------------------------------------
# Public URLs (Canonical)
# -----------------------------------------------------------------------
APP_PUBLIC_URL=http://localhost:5000
FRONTEND_PUBLIC_URL=http://localhost:3000

# -----------------------------------------------------------------------
# CORS + Redirect Allowlists
# -----------------------------------------------------------------------
WEB_ALLOWED_ORIGINS=http://localhost:5000,http://localhost:3001,http://localhost:8080,http://localhost:3000
REDIRECT_ALLOWED_ORIGINS=http://localhost:5000,http://localhost:3001,http://localhost:8080

# -----------------------------------------------------------------------
# HTTP Server / Proxy
# -----------------------------------------------------------------------
FASTIFY_TRUST_PROXY=1

# -----------------------------------------------------------------------
# Cookies
# -----------------------------------------------------------------------
COOKIE_ALLOWED_DOMAINS=localhost

# -----------------------------------------------------------------------
# Docs
# -----------------------------------------------------------------------
ENABLE_DOCS=true

# -----------------------------------------------------------------------
# Logging & Request Tracing
# -----------------------------------------------------------------------
LOG_LEVEL=info
LOG_PRETTY=true
REQUEST_ID_HEADER_NAME=x-request-id

# -----------------------------------------------------------------------
# Internationalization (i18n)
# -----------------------------------------------------------------------
I18N_HEADER_NAME=Accept-Language
I18N_QUERY_NAME=lang
I18N_DEFAULT_LOCALE=ar-SY

# -----------------------------------------------------------------------
# Database (Docker Service)
# -----------------------------------------------------------------------
POSTGRES_DB=harbor_api_kit
POSTGRES_USER=harbor_api_kit
POSTGRES_PASSWORD=harbor_api_kit_password
POSTGRES_PORT=5432

# -----------------------------------------------------------------------
# Database (App)
# -----------------------------------------------------------------------
DATABASE_URL=postgresql://harbor_api_kit:harbor_api_kit_password@localhost:5434/harbor_api_kit?schema=public

# -----------------------------------------------------------------------
# Cache / Queue (Redis)
# -----------------------------------------------------------------------
REDIS_URL=redis://127.0.0.1:6379
REDIS_PREFIX=hak
REDIS_DEFAULT_TTL_SEC=900

# -----------------------------------------------------------------------
# Security - CSRF
# -----------------------------------------------------------------------
CSRF_ENABLED=true
CSRF_HEADER_NAME=X-CSRF-Token
COOKIE_CSRF_NAME=__Host-csrf
CSRF_SAMESITE=lax
CSRF_COOKIE_SECURE=true

# -----------------------------------------------------------------------
# Security - Rate Limiting
# -----------------------------------------------------------------------
RATE_LIMIT_ENABLED=true
RATE_LIMIT_POINTS=60
RATE_LIMIT_DURATION_SEC=60
RATE_LIMIT_KEY_STRATEGY=ip
RATE_LIMIT_HEADER_PREFIX=RateLimit

# -----------------------------------------------------------------------
# Authentication - Session Cookies
# -----------------------------------------------------------------------
SESSION_TOKEN_COOKIE=__Host-session
SESSION_DATA_COOKIE=__Host-session-data
AUTH_SESSION_PERSISTENT_EXPIRES_IN_SEC=2592000
AUTH_SESSION_ROLLING_UPDATE_AGE_SEC=86400
BETTER_AUTH_SECRET=YOUR_BETTER_AUTH_SECRET
BETTER_AUTH_URL=http://localhost:5000/api/v1/auth

# -----------------------------------------------------------------------
# OAuth Providers
# -----------------------------------------------------------------------
GOOGLE_CLIENT_ID=YOUR_GOOGLE_CLIENT_ID
GOOGLE_CLIENT_SECRET=YOUR_GOOGLE_CLIENT_SECRET
GITHUB_CLIENT_ID=YOUR_GITHUB_CLIENT_ID
GITHUB_CLIENT_SECRET=YOUR_GITHUB_CLIENT_SECRET

# -----------------------------------------------------------------------
# Email Service (Resend)
# -----------------------------------------------------------------------
RESEND_API_KEY=YOUR_RESEND_API_KEY
RESEND_FROM_EMAIL=YOUR_RESEND_FROM_EMAIL
RESEND_FROM_NAME=YOUR_RESEND_FROM_NAME

# -----------------------------------------------------------------------
# Notifications - Retry Policy
# -----------------------------------------------------------------------
NOTIFY_EMAIL_RETRY_ATTEMPTS=5
NOTIFY_EMAIL_RETRY_DELAY_MS=5000

# -----------------------------------------------------------------------
# Tenant
# -----------------------------------------------------------------------
TENANT_STRATEGY=subdomain
TENANT_REQUIRED=true
TENANT_HEADER_NAME=X-Tenant

# -----------------------------------------------------------------------
# Storage
# -----------------------------------------------------------------------
STORAGE_DRIVER=r2

# // S3 / R2 / Spaces
S3_ENDPOINT=YOUR_S3_ENDPOINT
S3_REGION=YOUR_S3_REGION
S3_ACCESS_KEY_ID=YOUR_S3_ACCESS_KEY_ID
S3_SECRET_ACCESS_KEY=YOUR_S3_SECRET_ACCESS_KEY
S3_BUCKET=YOUR_S3_BUCKET

# GCS
# GCS_PROJECT_ID = 
# GCS_KEY_FILE = 
# GCS_BUCKET = 

# LOCAL_STORAGE_PATH=./uploads

# -----------------------------------------------------------------------
# Seed (Dev Only)
# -----------------------------------------------------------------------
SEED_ADMIN_EMAIL=YOUR_SEED_ADMIN_EMAIL
SEED_ADMIN_PASSWORD=YOUR_SEED_ADMIN_PASSWORD
SEED_ADMIN_FIRST_NAME=YOUR_SEED_ADMIN_FIRST_NAME
SEED_ADMIN_LAST_NAME=YOUR_SEED_ADMIN_LAST_NAME
SEED_ADMIN_LOCALE=ar-SY
ALLOW_PROD_SEED=true
