{
  "$schema": "https://unpkg.com/knip@latest/schema.json",
  "entry": [
    "src/main.ts",
    "src/app.module.ts",
    "export-project.js",
    "test/**/*.e2e-spec.ts",
    "test/**/*.contract-spec.ts",
    "test/jest-setup.ts"
  ],
  "project": ["src/**/*.ts", "test/**/*.ts"],
  "ignore": ["src/generated/**"]
}
