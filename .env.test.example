# -----------------------------------------------------------------------
# Test Environment Settings
# Copy this file to .env.test and adjust values as needed.
# Docker services: docker compose -f docker-compose.test.yml up -d
# -----------------------------------------------------------------------
APP_NAME="SaaS Core Platform API (Test)"
APP_ENV=test
APP_PORT=5001
APP_PUBLIC_URL=http://localhost:5001
FRONTEND_PUBLIC_URL=http://localhost:3000

# -----------------------------------------------------------------------
# API Documentation
# -----------------------------------------------------------------------
ENABLE_DOCS=false

# -----------------------------------------------------------------------
# Seed (used by prisma db seed)
# -----------------------------------------------------------------------
SEED_ADMIN_EMAIL=admin@coreapi.com
SEED_ADMIN_PASSWORD=StrongP@ssw0rd!
SEED_ADMIN_FIRST_NAME=Super
SEED_ADMIN_LAST_NAME=Admin
SEED_ADMIN_LOCALE=ar-SY

# -----------------------------------------------------------------------
# Logging
# -----------------------------------------------------------------------
LOG_LEVEL=error
LOG_PRETTY=true
REQUEST_ID_HEADER_NAME=x-request-id

# -----------------------------------------------------------------------
# Internationalization (i18n)
# -----------------------------------------------------------------------
I18N_HEADER_NAME=Accept-Language
I18N_QUERY_NAME=lang
I18N_DEFAULT_LOCALE=ar-SY

# -----------------------------------------------------------------------
# CORS
# -----------------------------------------------------------------------
WEB_ALLOWED_ORIGINS=http://localhost:5001,http://localhost:3000

# -----------------------------------------------------------------------
# Cookies
# -----------------------------------------------------------------------
COOKIE_ALLOWED_DOMAINS=localhost

# -----------------------------------------------------------------------
# Redirects
# -----------------------------------------------------------------------
REDIRECT_ALLOWED_ORIGINS=http://localhost:5001

# -----------------------------------------------------------------------
# HTTP Server / Proxy
# -----------------------------------------------------------------------
FASTIFY_TRUST_PROXY=1

# -----------------------------------------------------------------------
# Database Configuration (PostgreSQL Test Instance - port 5435)
# -----------------------------------------------------------------------
POSTGRES_DB=saas_core_test
POSTGRES_USER=test_user
POSTGRES_PASSWORD=test_password
POSTGRES_PORT=5435
DATABASE_URL=postgresql://test_user:test_password@localhost:5435/saas_core_test?schema=public

# -----------------------------------------------------------------------
# CSRF Protection
# -----------------------------------------------------------------------
CSRF_ENABLED=true
CSRF_HEADER_NAME=X-CSRF-Token
COOKIE_CSRF_NAME=__Host-csrf
CSRF_SAMESITE=lax
CSRF_COOKIE_SECURE=false

# -----------------------------------------------------------------------
# Cache / Queue (Redis Test Instance - port 6380)
# -----------------------------------------------------------------------
REDIS_URL=redis://localhost:6380
REDIS_PREFIX=scp
REDIS_DEFAULT_TTL_SEC=900

# -----------------------------------------------------------------------
# Rate Limiting
# -----------------------------------------------------------------------
RATE_LIMIT_ENABLED=true
RATE_LIMIT_POINTS=60
RATE_LIMIT_DURATION_SEC=60
RATE_LIMIT_KEY_STRATEGY=ip
RATE_LIMIT_HEADER_PREFIX=RateLimit

# -----------------------------------------------------------------------
# Authentication
# -----------------------------------------------------------------------
SESSION_TOKEN_COOKIE=__Host-session-test
SESSION_DATA_COOKIE=__Host-session-data-test
BETTER_AUTH_SECRET=test_secret_must_be_long_enough_for_security_checks
BETTER_AUTH_URL=http://localhost:5001/api/v1/auth

# OAuth - use test/dummy credentials
GOOGLE_CLIENT_ID=YOUR_TEST_GOOGLE_CLIENT_ID
GOOGLE_CLIENT_SECRET=YOUR_TEST_GOOGLE_CLIENT_SECRET
GITHUB_CLIENT_ID=YOUR_TEST_GITHUB_CLIENT_ID
GITHUB_CLIENT_SECRET=YOUR_TEST_GITHUB_CLIENT_SECRET

# -----------------------------------------------------------------------
# Email Service (Mock - not actually sent in test env)
# -----------------------------------------------------------------------
RESEND_API_KEY=re_test_123456789
RESEND_FROM_EMAIL=test@example.com
RESEND_FROM_NAME=TestApp

# -----------------------------------------------------------------------
# Tenant
# -----------------------------------------------------------------------
TENANT_STRATEGY=header
TENANT_REQUIRED=false
TENANT_HEADER_NAME=X-Tenant

# -----------------------------------------------------------------------
# Storage (Local driver for tests)
# -----------------------------------------------------------------------
STORAGE_DRIVER=local
LOCAL_STORAGE_PATH=./test-uploads
